# === 分路链式工业互联网系统 V5.0 · 生产环境配置 ===
# 复制为 .env 后修改所有密码

# --- PostgreSQL ---
POSTGRES_USER=fenlu
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=fenlu_v5

# --- Redis ---
REDIS_PASSWORD=CHANGE_ME_redis_password

# --- MinIO (对象存储) ---
MINIO_USER=fenlu
MINIO_PASSWORD=CHANGE_ME_minio_password

# --- JWT (必改! 用 openssl rand -hex 32 生成) ---
JWT_SECRET=CHANGE_ME_use_openssl_rand_hex_32

# --- 应用 ---
APP_ENV=production
LOG_LEVEL=INFO
WEB_PORT=80
