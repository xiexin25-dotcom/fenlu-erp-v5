# 复制为 .env 后修改
DATABASE_URL=postgresql+asyncpg://fenlu:fenlu_dev@localhost:5432/fenlu_v5
REDIS_URL=redis://localhost:6379/0

# 必改! 用 `openssl rand -hex 32` 生成
JWT_SECRET=dev-secret-change-me-in-production
